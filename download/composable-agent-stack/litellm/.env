# ============================================================
# LiteLLM Provider API Keys
# ============================================================
# Only fill in the keys for providers you want to use.
# All keys are read by LiteLLM config.yaml via os.environ/
# You never need to put API keys in any agent tool config.
# ============================================================

# ---- LITELLM MASTER KEY (required) ----
# This is the admin key for the LiteLLM proxy.
# All agent tools use THIS key (or a virtual key derived from it).
LITELLM_MASTER_KEY=sk-stack-master-key-change-me

# ---- DATABASE (required) ----
DATABASE_URL=postgresql://litellm:litellm_secret@litellm-db:5432/litellm

# ---- OpenAI ----
OPENAI_API_KEY=sk-...

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Google Gemini ----
GEMINI_API_KEY=AIza...

# ---- DeepSeek ----
DEEPSEEK_API_KEY=sk-...

# ---- OpenRouter (200+ models, one key) ----
OPENROUTER_API_KEY=sk-or-...

# ---- AWS Bedrock (optional) ----
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# ---- Azure OpenAI (optional) ----
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ---- Default model selection for each tool ----
AGENT_S_MODEL=gpt-4o
BROWSER_USE_MODEL=gpt-4o
OPENHANDS_MODEL=gpt-4o
